                  "auth": {
                    "authType": "none",
                    "authActive": false
                  },
                  "body": {
                    "contentType": "application/json",
                    "body": "{\"crew_member_id\":\"EMP-101\",\"role\":\"captain\",\"flight_id\":\"TK-1042\"}"
                  },
                  "requestVariables": [],
