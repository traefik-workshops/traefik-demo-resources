{{- if include "airlines.mc.isParentMode" . }}
{{- if .Values.hoppscotch.enabled }}
{{- $domain := include "airlines.domain" . }}
apiVersion: v1
kind: ConfigMap
metadata:
  name: airlines-hoppscotch-collection
  labels:
    {{- include "airlines.labels" . | nindent 4 }}
data:
  collection.json: |
    {
      "v": 5,
      "name": "Traefik Airlines",
      "folders": [
        {
          "v": 5,
          "name": "Airlines APIs",
          "folders": [
        {
          "v": 5,
          "name": "Flight Operations",
          "folders": [
            {
              "v": 5,
              "name": "Flights",
              "folders": [],
              "requests": [
                {
                  "v": "5",
                  "id": "req-flights-token",
                  "name": "Get Dispatcher Token",
                  "method": "POST",
                  "endpoint": "{{ include "airlines.oidc.issuerUrl" . }}/protocol/openid-connect/token",
                  "params": [],
                  "headers": [
                    {
                      "key": "Content-Type",
                      "value": "application/x-www-form-urlencoded",
                      "active": true
                    }
                  ],
                  "preRequestScript": "",
                  "testScript": "pw.test(\"Token received\", () => { pw.expect(pw.response.status).toBe(200); pw.expect(pw.response.body.access_token).toBeType(\"string\"); });\nhopp.env.global.set(\"token\", pw.response.body.access_token);",
                  "auth": {
                    "authType": "none",
                    "authActive": false
                  },
                  "body": {
                    "contentType": "text/plain",
                    "body": "grant_type=password&client_id=traefik&client_secret=NoTgoLZpbrr5QvbNDIRIvmZOhe9wI0r0&username=dispatcher&password=topsecretpassword&scope=openid+group"
                  },
                  "requestVariables": [],
                  "responses": {}
                },
                {
                  "v": "5",
                  "id": "req-flights-list",
                  "name": "List All Flights",
                  "method": "GET",
                  "endpoint": "https://flights.{{ $domain }}/v2/flights",
                  "params": [],
                  "headers": [
                    {
                      "key": "Authorization",
                      "value": "Bearer <<token>>",
                      "active": true
                    }
                  ],
                  "preRequestScript": "",
                  "testScript": "pw.test(\"Status is 200\", () => { pw.expect(pw.response.status).toBe(200); });",
                  "auth": {
                    "authType": "none",
                    "authActive": false
                  },
                  "body": {
                    "contentType": null,
                    "body": null
                  },
                  "requestVariables": [],
                  "responses": {}
                },
                {
                  "v": "5",
                  "id": "req-flights-search",
                  "name": "Search Flights",
                  "method": "GET",
                  "endpoint": "https://flights.{{ $domain }}/v2/flights/search",
                  "params": [
                    {
                      "key": "origin",
                      "value": "IST",
                      "active": true
                    },
                    {
                      "key": "destination",
                      "value": "JFK",
                      "active": true
                    }
                  ],
                  "headers": [
                    {
                      "key": "Authorization",
                      "value": "Bearer <<token>>",
                      "active": true
                    }
                  ],
                  "preRequestScript": "",
                  "testScript": "pw.test(\"Status is 200\", () => { pw.expect(pw.response.status).toBe(200); });",
                  "auth": {
                    "authType": "none",
                    "authActive": false
                  },
                  "body": {
                    "contentType": null,
                    "body": null
                  },
                  "requestVariables": [],
                  "responses": {}
                },
                {
                  "v": "5",
                  "id": "req-flights-create",
                  "name": "Create Flight",
                  "method": "POST",
                  "endpoint": "https://flights.{{ $domain }}/v2/flights",
                  "params": [],
                  "headers": [
                    {
                      "key": "Authorization",
                      "value": "Bearer <<token>>",
                      "active": true
                    },
                    {
                      "key": "Content-Type",
                      "value": "application/json",
                      "active": true
                    }
                  ],
                  "preRequestScript": "",
                  "testScript": "pw.test(\"Flight created\", () => { pw.expect(pw.response.status).toBe(201); pw.expect(pw.response.body.flight_id).toBeType(\"string\"); });\nhopp.env.global.set(\"new_flight_id\", pw.response.body.flight_id);",
                  "auth": {
                    "authType": "none",
                    "authActive": false
                  },
                  "body": {
                    "contentType": "application/json",
                    "body": "{\"flight_number\":\"TK-9001\",\"origin\":\"SFO\",\"destination\":\"NRT\",\"departure_time\":\"2026-06-01T10:00:00Z\",\"arrival_time\":\"2026-06-01T18:00:00Z\",\"aircraft\":\"A350-900\"}"
                  },
                  "requestVariables": [],
                  "responses": {}
                },
                {
                  "v": "5",
                  "id": "req-flights-get",
                  "name": "Get Flight",
                  "method": "GET",
                  "endpoint": "https://flights.{{ $domain }}/v2/flights/<<new_flight_id>>",
                  "params": [],
                  "headers": [
                    {
                      "key": "Authorization",
                      "value": "Bearer <<token>>",
                      "active": true
                    }
                  ],
                  "preRequestScript": "",
                  "testScript": "pw.test(\"Status is 200\", () => { pw.expect(pw.response.status).toBe(200); });",
                  "auth": {
                    "authType": "none",
                    "authActive": false
                  },
                  "body": {
                    "contentType": null,
                    "body": null
                  },
                  "requestVariables": [],
                  "responses": {}
                },
                {
                  "v": "5",
                  "id": "req-flights-v1",
                  "name": "Get Flights v1 (Deprecated \u2014 check headers)",
                  "method": "GET",
                  "endpoint": "https://flights.{{ $domain }}/v1/flights",
                  "params": [],
                  "headers": [
                    {
                      "key": "Authorization",
                      "value": "Bearer <<token>>",
                      "active": true
                    }
                  ],
                  "preRequestScript": "",
                  "testScript": "pw.test(\"Status is 200\", () => { pw.expect(pw.response.status).toBe(200); });\nvar depHeader = pw.response.headers.find(function(h) { return h.key === \"deprecation\"; });\nvar sunsetHeader = pw.response.headers.find(function(h) { return h.key === \"sunset\"; });\npw.test(\"Deprecation header set\", () => { pw.expect(depHeader && depHeader.value).toBe(\"true\"); });\npw.test(\"Sunset header present\", () => { pw.expect(sunsetHeader && sunsetHeader.value).toBeType(\"string\"); });",
                  "auth": {
                    "authType": "none",
                    "authActive": false
                  },
                  "body": {
                    "contentType": null,
                    "body": null
                  },
                  "requestVariables": [],
                  "responses": {}
                },
                {
                  "v": "5",
                  "id": "req-flights-delete-blocked",
                  "name": "Cancel Flight - Dispatcher Blocked (Expect 403)",
                  "method": "DELETE",
                  "endpoint": "https://flights.{{ $domain }}/v2/flights/<<new_flight_id>>",
                  "params": [],
                  "headers": [
                    {
                      "key": "Authorization",
                      "value": "Bearer <<token>>",
                      "active": true
                    }
                  ],
                  "preRequestScript": "",
                  "testScript": "pw.test(\"Dispatcher cannot DELETE\", () => { pw.expect(pw.response.status).toBe(403); });",
                  "auth": {
                    "authType": "none",
                    "authActive": false
                  },
                  "body": {
                    "contentType": null,
                    "body": null
                  },
                  "requestVariables": [],
                  "responses": {}
                },
                {
                  "v": "5",
                  "id": "req-flights-admin-token",
                  "name": "Get Admin Token",
                  "method": "POST",
                  "endpoint": "{{ include "airlines.oidc.issuerUrl" . }}/protocol/openid-connect/token",
                  "params": [],
                  "headers": [
                    {
                      "key": "Content-Type",
                      "value": "application/x-www-form-urlencoded",
                      "active": true
                    }
                  ],
                  "preRequestScript": "",
                  "testScript": "pw.test(\"Token received\", () => { pw.expect(pw.response.status).toBe(200); pw.expect(pw.response.body.access_token).toBeType(\"string\"); });\nhopp.env.global.set(\"token\", pw.response.body.access_token);",
                  "auth": {
                    "authType": "none",
                    "authActive": false
                  },
                  "body": {
                    "contentType": "text/plain",
                    "body": "grant_type=password&client_id=traefik&client_secret=NoTgoLZpbrr5QvbNDIRIvmZOhe9wI0r0&username=admin&password=topsecretpassword&scope=openid+group"
                  },
                  "requestVariables": [],
                  "responses": {}
                },
                {
                  "v": "5",
                  "id": "req-flights-delete-admin",
                  "name": "Cancel Flight - Admin Allowed (Expect 204)",
                  "method": "DELETE",
                  "endpoint": "https://flights.{{ $domain }}/v2/flights/<<new_flight_id>>",
                  "params": [],
                  "headers": [
                    {
                      "key": "Authorization",
                      "value": "Bearer <<token>>",
                      "active": true
                    }
                  ],
                  "preRequestScript": "",
                  "testScript": "pw.test(\"Admin DELETE succeeds\", () => { pw.expect(pw.response.status).toBe(200); });",
                  "auth": {
                    "authType": "none",
                    "authActive": false
                  },
                  "body": {
                    "contentType": null,
                    "body": null
                  },
                  "requestVariables": [],
                  "responses": {}
                }
              ],
              "auth": {
                "authType": "none",
                "authActive": false
              },
              "headers": []
            },
